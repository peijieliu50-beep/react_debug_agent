# ============================================================
# Streamlit Secrets 模板（secrets.toml）
# ============================================================
# 用法：
#   - 【云端部署】不要上传本文件！在 Streamlit Cloud 后台
#     "App settings → Secrets" 里粘贴下面的内容并填好真实值。
#   - 【本地测试在线模式】把本文件复制为同目录下的 secrets.toml，
#     填入真实值即可（secrets.toml 已被 .gitignore 忽略，不会泄露）。
# ============================================================

# DeepSeek API 密钥（必填）—— 服务端持有，访客看不到也改不了
DEEPSEEK_API_KEY = "sk-在这里填你的真实密钥"

# 访问口令（必填）—— 访客需输入此口令才能进入；不设则任何人可用
ACCESS_PASSWORD = "给你朋友的口令"

# 每日全局调用次数上限（防止密钥被刷爆烧钱）；0 或留空 = 不限制
DAILY_CALL_LIMIT = "50"
